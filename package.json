{
  "name": "proteus-author",
  "version": "0.8.1",
  "description": "An authoring application for .prot files.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src/ --ext .vue --ext .ts",
    "bump:patch": "bun ./scripts/bump-version.ts patch",
    "bump:minor": "bun ./scripts/bump-version.ts minor",
    "bump:major": "bun ./scripts/bump-version.ts major"
  },
  "repository": "https://github.com/howardah/proteus-author",
  "author": {
    "name": "Adam Howard",
    "url": "https://github.com/howardah"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.0",
    "@tauri-apps/cli": "^2.10.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.1.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "@tauri-apps/plugin-http": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-os": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@vueuse/core": "^14.2.0",
    "audio-buffer-from": "^1.1.1",
    "case-anything": "^3.1.2",
    "element-plus": "^2.2.17",
    "konva": "^10.2.0",
    "lodash": "^4.17.21",
    "peaks.js": "^4.0.0",
    "pinia": "^3.0.4",
    "tone": "^15.1.22",
    "vue": "^3.2.37",
    "vue3-dropzone": "^2.0.1",
    "vuedraggable": "^2.24.3",
    "waveform-data": "^4.3.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.184",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.6.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-vue": "^10.7.0",
    "prettier": "^3.8.1",
    "sass": "^1.55.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.4"
