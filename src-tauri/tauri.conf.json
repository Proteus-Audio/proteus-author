{
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "category": "Music",
    "copyright": "",
    "targets": "all",
    "externalBin": [
      "../ffmpeg/small/proteus-author-ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "protproject"
        ],
        "name": "Proteus Author Project",
        "description": "Proteus Author Project File",
        "role": "Editor",
        "mimeType": "application/x-proteus-project"
      }
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "shortDescription": "",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "productName": "Proteus Author",
  "version": "0.11.0",
  "identifier": "com.proteus.author",
  "plugins": {},
  "app": {
    "withGlobalTauri": false,
    "security": {
      "assetProtocol": {
        "scope": [
          "$HOME/**/*"
        ],
        "enable": true
      },
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; worker-src * data: blob:; child-src * data: blob:; connect-src ipc: http://ipc.localhost 'self' asset: https://asset.localhost; media-src * asset: https://asset.localhost data: blob:;"
    }
  }
}
